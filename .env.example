# Public site URL for metadata, sitemap, and canonical links (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://your-domain.com

NEXT_PUBLIC_SANITY_PROJECT_ID=replaceprojectid
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-02-01

# Optional. Viewer token for draft content and standalone live preview (sanity.io/manage → API → Tokens).
SANITY_API_READ_TOKEN=

# Required for signup form — saves courseSignup documents in Sanity.
# Create at sanity.io/manage → API → Tokens (Editor permissions).
SANITY_API_WRITE_TOKEN=

# Optional. Sends email to notificationEmail from Studio (default ruslannikolov1@gmail.com).
# Without Mailtrap, submissions appear in Studio only.

# Production: Email Sending → API Tokens (Transactional Stream)
MAILTRAP_API_TOKEN=
MAILTRAP_FROM_EMAIL=Aura & Bloom <hello@yourdomain.com>

# Testing: Email Sandbox → inbox → Integration → API
# MAILTRAP_USE_SANDBOX=true
# MAILTRAP_INBOX_ID=your_inbox_id
